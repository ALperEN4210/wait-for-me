#include <SoftwareSerial.h>

byte cmd[9] = {0xFF, 0x01, 0x86, 0x00, 0x00, 0x00, 0x00, 0x00, 0x79};
byte response[9];

void testPins(int rxPin, int txPin) {
  SoftwareSerial test(rxPin, txPin);
  test.begin(9600);
  delay(100);
  
  while(test.available()) test.read();
  test.write(cmd, 9);
  
  long start = millis();
  while(millis() - start < 2000) {
    if(test.available() >= 9) break;
  }
  
  Serial.print("RX=");
  Serial.print(rxPin);
  Serial.print(" TX=");
  Serial.print(txPin);
  Serial.print(" -> ");
  
  if(test.available() >= 9) {
    for(int i = 0; i < 9; i++) response[i] = test.read();
    if(response[0] == 0xFF && response[1] == 0x86) {
      int co2 = (response[2] << 8) | response[3];
      Serial.print("CO2: ");
      Serial.print(co2);
      Serial.println(" ppm ✓ BULUNDU!");
    } else {
      Serial.println("Yanlis veri");
    }
  } else {
    Serial.println("Veri yok");
  }
  test.end();
  delay(500);
}

void setup() {
  Serial.begin(9600);
  delay(5000);
  Serial.println("Pin testi basliyor...");
}

void loop() {
  testPins(10, 11);
  testPins(11, 10);
  testPins(2, 3);
  testPins(3, 2);
  testPins(4, 5);
  testPins(5, 4);
  Serial.println("--- Tekrar ---");
  delay(3000);
}