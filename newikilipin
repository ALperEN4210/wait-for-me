#include <SoftwareSerial.h>

byte cmd[9] = {0xFF, 0x01, 0x86, 0x00, 0x00, 0x00, 0x00, 0x00, 0x79};
byte response[9];

int rxPin, txPin;

void setup() {
  Serial.begin(9600);
  delay(5000);
  Serial.println("Test basliyor");
}

void loop() {
  int pins[6][2] = {{10,11},{11,10},{2,3},{3,2},{4,5},{5,4}};
  
  for(int p = 0; p < 6; p++) {
    rxPin = pins[p][0];
    txPin = pins[p][1];
    
    SoftwareSerial ss(rxPin, txPin);
    ss.begin(9600);
    delay(200);
    
    while(ss.available()) ss.read();
    ss.write(cmd, 9);
    
    long t = millis();
    while(millis() - t < 2000) {
      if(ss.available() >= 9) break;
    }
    
    Serial.print("RX=");
    Serial.print(rxPin);
    Serial.print(" TX=");
    Serial.print(txPin);
    Serial.print(" -> ");
    
    if(ss.available() >= 9) {
      for(int i = 0; i < 9; i++) response[i] = ss.read();
      if(response[0] == 0xFF) {
        int co2 = (response[2] << 8) | response[3];
        Serial.print("CO2: ");
        Serial.print(co2);
        Serial.println(" ppm BULUNDU!");
      } else {
        Serial.println("Yanlis veri");
      }
    } else {
      Serial.println("Veri yok");
    }
    ss.end();
    delay(300);
  }
  Serial.println("---");
  delay(3000);
}